{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:unit:ci": "vitest --run --coverage --coverage.all",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=line",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint:eslint:ci": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "test:cucumber": "cucumber-js --loader ts-node/esm --import './features/step_definitions/**/*.ts'"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/bun": "^1.3.14",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.18.1",
    "bun": "^1.3.14",
    "jose": "^6.2.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qrcode": "^1.5.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@prettier/plugin-oxc": "^0.2.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/cucumber": "^7.0.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vitest/ui": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-oxlint": "^1.72.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxlint": "^1.72.0",
    "prettier": "3.9.3",
    "resize-observer-polyfill": "^1.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-csp-guard": "^4.0.1",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6",
    "@vitest/coverage-v8": "^4.1.10"
  }
}

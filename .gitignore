# Created by https://www.toptal.com/developers/gitignore/api/intellij+all,go,vuejs
# Edit at https://www.toptal.com/developers/gitignore?templates=intellij+all,go,vuejs

### Go ###
# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

### Intellij+all ###
# Covers JetBrains IDEs: IntelliJ, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio, WebStorm and Rider
# Reference: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839

# User-specific stuff
frontend/.idea/**/workspace.xml
backend/.idea/**/workspace.xml
frontend/.idea/**/tasks.xml
backend/.idea/**/tasks.xml
frontend/.idea/**/usage.statistics.xml
backend/.idea/**/usage.statistics.xml
frontend/.idea/**/dictionaries
backend/.idea/**/dictionaries
frontend/.idea/**/shelf
backend/.idea/**/shelf

# AWS User-specific
frontend/.idea/**/aws.xml
backend/.idea/**/aws.xml

# Generated files
frontend/.idea/**/contentModel.xml
backend/.idea/**/contentModel.xml

# Sensitive or high-churn files
frontend/.idea/**/dataSources/
backend/.idea/**/dataSources/
frontend/.idea/**/dataSources.ids
backend/.idea/**/dataSources.ids
frontend/.idea/**/dataSources.local.xml
backend/.idea/**/dataSources.local.xml
frontend/.idea/**/sqlDataSources.xml
backend/.idea/**/sqlDataSources.xml
frontend/.idea/**/dynamic.xml
backend/.idea/**/dynamic.xml
frontend/.idea/**/uiDesigner.xml
backend/.idea/**/uiDesigner.xml
frontend/.idea/**/dbnavigator.xml
backend/.idea/**/dbnavigator.xml

# Gradle
frontend/.idea/**/gradle.xml
backend/.idea/**/gradle.xml
frontend/.idea/**/libraries
backend/.idea/**/libraries

# Gradle and Maven with auto-import
# When using Gradle or Maven with auto-import, you should exclude module files,
# since they will be recreated, and may cause churn.  Uncomment if using
# auto-import.
#frontend/.idea/artifacts
#backend/.idea/artifacts
#frontend/.idea/compiler.xml
#backend/.idea/compiler.xml
#frontend/.idea/jarRepositories.xml
#backend/.idea/jarRepositories.xml
#frontend/.idea/modules.xml
#backend/.idea/modules.xml
#frontend/.idea/*.iml
#backend/.idea/*.iml
#frontend/.idea/modules
#backend/.idea/modules
# *.iml
# *.ipr

# CMake
cmake-build-*/

# Mongo Explorer plugin
frontend/.idea/**/mongoSettings.xml
backend/.idea/**/mongoSettings.xml

# File-based project format
frontend/*.iws
backend/*.iws

# IntelliJ
frontend/out/
backend/out/

# mpeltonen/sbt-idea plugin
frontend/.idea_modules/
backend/.idea_modules/

# JIRA plugin
frontend/atlassian-ide-plugin.xml
backend/atlassian-ide-plugin.xml

# Cursive Clojure plugin
frontend/.idea/replstate.xml
backend/.idea/replstate.xml

# SonarLint plugin
frontend/.idea/sonarlint/
backend/.idea/sonarlint/

# Crashlytics plugin (for Android Studio and IntelliJ)
frontend/com_crashlytics_export_strings.xml
backend/com_crashlytics_export_strings.xml
frontend/crashlytics.properties
backend/crashlytics.properties
frontend/crashlytics-build.properties
backend/crashlytics-build.properties
frontend/fabric.properties
backend/fabric.properties

# Editor-based Rest Client
frontend/.idea/httpRequests
backend/.idea/httpRequests

# Android studio 3.1+ serialized cache file
frontend/.idea/caches/build_file_checksums.ser
backend/.idea/caches/build_file_checksums.ser

### Intellij+all Patch ###
# Ignore everything but code style settings and run configurations
# that are supposed to be shared within teams.

frontend/.idea/*
backend/.idea/*

frontend/.idea/codeStyles
backend/.idea/codeStyles
frontend/.idea/runConfigurations
backend/.idea/runConfigurations

### Vuejs ###
# Recommended template: Node.gitignore

frontend/node_modules/
backend/node_modules/
frontend/dist/
backend/dist/
frontend/npm-debug.log
backend/npm-debug.log
frontend/yarn-error.log
backend/yarn-error.log

# End of https://www.toptal.com/developers/gitignore/api/intellij+all,go,vuejs

.scannerwork/*
/data/*
node_modules/*

